print(res$morans_i$test_set)
cat("\n--- Monte Carlo Moran's I (all 2019 tracts) ---\n")
print(res$morans_i$all_2019_mc)
# ---- 2019 predictions preview ------------------------------------------
cat("\n--- 2019 Full City Predictions (first 10 rows) ---\n")
print(head(res$predictions$all_2019_preds, 10))
invisible(res)  # return list silently so caller can assign it
}
res <- reload_xgb_results("xgb_expanding_results.rds")
vi_matrix <- xgb.importance(
feature_names = pred_vars,
model         = final_xgb
)
# Tidy tibble — keep all three XGBoost importance metrics
vi_tib <- as_tibble(vi_matrix) %>%
rename(Variable = Feature) %>%
arrange(desc(Gain))   # Gain = most comparable to RF permutation importance
p_vi <- ggplot(vi_tib %>% head(20),
aes(x = reorder(Variable, Gain), y = Gain)) +
geom_bar(stat = "identity", fill = "#E66101") +
coord_flip() +
labs(
title = "XGBoost Variable Importance (Gain)",
x     = NULL,
y     = "Gain"
) +
theme_minimal(base_size = 12)
print(p_vi)
