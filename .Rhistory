# Load required libraries
library(readxl)
library(stringr)
library(dplyr)
library(Hmisc)
# Countries to analyse
countries <- c("Belgium", "Spain", "Poland")
# Task variables of interest
# 4.A.2.a.4  Analyzing Data or Information
# 4.A.2.b.2  Thinking Creatively
# 4.A.4.a.1  Interpreting the Meaning of Information for Others
task_vars <- c("t_4A2a4", "t_4A2b2", "t_4A4a1")
# Number of 1-digit ISCO-08 occupation categories
n_isco <- 9
# File paths
path_eurostat <- "Data/Eurostat_employment_isco.xlsx"
path_onet     <- "Data/onet_tasks.csv"
# Read O*NET task data
task_data <- read.csv(path_onet)
# Keep only the 1st digit of the ISCO-08 code so we can merge with Eurostat data
task_data$isco08_1dig <- str_sub(task_data$isco08, 1, 1) %>% as.numeric()
# Aggregate task values to 1-digit ISCO level using mean
# Remove the now-redundant detailed code column
aggdata <- aggregate(task_data, by = list(task_data$isco08_1dig), FUN = mean, na.rm = TRUE)
aggdata$isco08 <- NULL
# Use a loop to read all 9 ISCO sheets and add an ISCO identifier column
# Replace 9 separate read_excel() calls and 9 separate $ISCO <- n assignments
# label which occupation category this row belongs to
isco_list <- lapply(1:n_isco, function(i) {
sheet_data       <- read_excel(path_eurostat, sheet = paste0("ISCO", i))
sheet_data$ISCO  <- i
return(sheet_data)
})
# Stack all occupation sheets into one data frame
all_data <- do.call(rbind, isco_list)
for (country in countries) {
# Sum all 9 ISCO columns for this country (one value per time-period row in isco_list[[i]])
# Rebuild the total from the individual sheets to be explicit about what we sum
total_col <- paste0("total_", country)
share_col <- paste0("share_", country)
# Calculate total workers per time period (same value repeated for all 9 ISCO rows)
country_totals <- Reduce("+", lapply(isco_list, function(df) df[[country]]))
# Replicate the total n_isco times so it aligns with the stacked all_data frame
all_data[[total_col]] <- rep(country_totals, times = n_isco)
# Occupation share = this ISCO's employment / total employment in that period
all_data[[share_col]] <- all_data[[country]] / all_data[[total_col]]
}
# Merge employment data with task data
combined <- left_join(all_data, aggdata, by = c("ISCO" = "isco08_1dig"))
# Standardise values using weighted mean and SD
weighted_standardise <- function(x, weights) {
w_mean <- wtd.mean(x, weights)
w_sd   <- sqrt(wtd.var(x, weights))
return((x - w_mean) / w_sd)
}
# Apply standardisation for every combination of country and task variable
for (country in countries) {
share_col <- paste0("share_", country)
for (task in task_vars) {
std_col <- paste0("std_", country, "_", task)
combined[[std_col]] <- weighted_standardise(combined[[task]], combined[[share_col]])
}
}
# Sum across the three task columns row-wisefor (country in countries) {
std_cols  <- paste0("std_", country, "_", task_vars)
nrca_col  <- paste0(country, "_NRCA")
combined[[nrca_col]] <- rowSums(combined[, std_cols], na.rm = TRUE)
}
# Apply standardisation for every combination of country and task variable
for (country in countries) {
share_col <- paste0("share_", country)
for (task in task_vars) {
std_col <- paste0("std_", country, "_", task)
combined[[std_col]] <- weighted_standardise(combined[[task]], combined[[share_col]])
}
}
# Apply standardisation for every combination of country and task variable
for (country in countries) {
share_col <- paste0("share_", country)
for (task in task_vars) {
std_col <- paste0("std_", country, "_", task)
combined[[std_col]] <- weighted_standardise(combined[[task]], combined[[share_col]])
}
}
# Standardise the NRCA index itself
for (country in countries) {
share_col    <- paste0("share_", country)
nrca_col     <- paste0(country, "_NRCA")
std_nrca_col <- paste0("std_", country, "_NRCA")
combined[[std_nrca_col]] <- weighted_standardise(combined[[nrca_col]], combined[[share_col]])
}
# Apply standardisation for every combination of country and task variable
for (country in countries) {
share_col <- paste0("share_", country)
for (task in task_vars) {
std_col <- paste0("std_", country, "_", task)
combined[[std_col]] <- weighted_standardise(combined[[task]], combined[[share_col]])
}
}
# NRCA = sum of the three standardised task scores for each country
for (country in countries) {
std_cols  <- paste0("std_", country, "_", task_vars)   # e.g. std_Belgium_t_4A2a4, ...
nrca_col  <- paste0(country, "_NRCA")
# Sum across the three task columns row-wise
combined[[nrca_col]] <- rowSums(combined[, std_cols], na.rm = TRUE)
}
# Standardise the NRCA index itself
for (country in countries) {
share_col    <- paste0("share_", country)
nrca_col     <- paste0(country, "_NRCA")
std_nrca_col <- paste0("std_", country, "_NRCA")
combined[[std_nrca_col]] <- weighted_standardise(combined[[nrca_col]], combined[[share_col]])
}
# Store one aggregated data frame per country
agg_results <- list()
for (country in countries) {
share_col    <- paste0("share_", country)
std_nrca_col <- paste0("std_", country, "_NRCA")
multip_col   <- paste0("multip_", country, "_NRCA")
# Multiply standardised NRCA by occupation share (weighted mean numerator)
combined[[multip_col]] <- combined[[std_nrca_col]] * combined[[share_col]]
# Sum over occupations within each time period (= weighted mean)
agg_results[[country]] <- aggregate(
combined[[multip_col]],
by  = list(TIME = combined$TIME),
FUN = sum,
na.rm = TRUE
)
names(agg_results[[country]])[2] <- "NRCA"   # rename the value column for clarity
}
# Plot NRCA over time for each country
n_periods    <- nrow(agg_results[[countries[1]]])
label_breaks <- seq(1, n_periods, by = 3)
for (country in countries) {
agg <- agg_results[[country]]
plot(
agg$NRCA,
xaxt  = "n",
main  = paste("NRCA Task Content Intensity –", country),
xlab  = "Time Period",
ylab  = "Weighted Mean Standardised NRCA"
)
axis(1, at = label_breaks, labels = agg$TIME[label_breaks])
}
# Countries to analyse
countries <- c("Belgium", "Spain", "Poland")
# Task variables of interest
# 4.A.2.a.4  Analyzing Data or Information
# 4.A.2.b.2  Thinking Creatively
# 4.A.4.a.1  Interpreting the Meaning of Information for Others
task_vars <- c("t_4A2a4", "t_4A2b2", "t_4A4a1")
# Extract the CSV file
task_data <- read.csv("Data/onet_tasks.csv")
# Keep only the first digit of ISCO code
task_data$isco08_1dig <- str_sub(task_data$isco08, 1, 1) %>% as.numeric()
# Aggregate task values to 1-digit ISCO level
aggdata <- aggregate(task_data, by = list(task_data$isco08_1dig), FUN = mean, na.rm = TRUE)
aggdata$isco08 <- NULL
# Use a loop instead of reading each sheet separately
isco_list <- list()
for (i in 1:9) {
isco_list[[i]]       <- read_excel("Data/Eurostat_employment_isco.xlsx", sheet = paste0("ISCO", i))
isco_list[[i]]$ISCO  <- i
}
# Stack all sheets into one data frame
all_data <- do.call(rbind, isco_list)
# Calculate totals and shares for each country
for (country in countries) {
# Sum employment across all 9 ISCO sheets for this country
country_total <- Reduce("+", lapply(isco_list, function(df) df[[country]]))
# Repeat 9 times to match the stacked data frame
all_data[[paste0("total_", country)]] <- rep(country_total, times = 9)
# Share = this occupation / total
all_data[[paste0("share_", country)]] <- all_data[[country]] / all_data[[paste0("total_", country)]]
}
# Merge employment data with task data
combined <- left_join(all_data, aggdata, by = c("ISCO" = "isco08_1dig"))
# Standardise task variables using a function
wtd_standardise <- function(x, weights) {
w_mean <- wtd.mean(x, weights)
w_sd   <- sqrt(wtd.var(x, weights))
return((x - w_mean) / w_sd)
}
# Apply it for every country and every task variable
for (country in countries) {
for (task in task_vars) {
combined[[paste0("std_", country, "_", task)]] <- wtd_standardise(
combined[[task]],
combined[[paste0("share_", country)]]
)
}
}
for (country in countries) {
# NRCA = sum of the three standardised task scores
combined[[paste0(country, "_NRCA")]] <-
combined[[paste0("std_", country, "_t_4A2a4")]] +
combined[[paste0("std_", country, "_t_4A2b2")]] +
combined[[paste0("std_", country, "_t_4A4a1")]]
# Standardise NRCA as well
combined[[paste0("std_", country, "_NRCA")]] <- wtd_standardise(
combined[[paste0(country, "_NRCA")]],
combined[[paste0("share_", country)]]
)
# Multiply by share (for weighted aggregation)
combined[[paste0("multip_", country, "_NRCA")]] <-
combined[[paste0("std_", country, "_NRCA")]] * combined[[paste0("share_", country)]]
}
# Aggregate to country-time level
agg_Belgium <- aggregate(combined$multip_Belgium_NRCA, by = list(combined$TIME), FUN = sum, na.rm = TRUE)
agg_Spain   <- aggregate(combined$multip_Spain_NRCA,   by = list(combined$TIME), FUN = sum, na.rm = TRUE)
agg_Poland  <- aggregate(combined$multip_Poland_NRCA,  by = list(combined$TIME), FUN = sum, na.rm = TRUE)
plot(agg_Poland$x, xaxt = "n", main = "Poland NRCA", xlab = "Time", ylab = "NRCA")
axis(1, at = seq(1, nrow(agg_Poland), 3), labels = agg_Poland$Group.1[seq(1, nrow(agg_Poland), 3)])
plot(agg_Spain$x, xaxt = "n", main = "Spain NRCA", xlab = "Time", ylab = "NRCA")
axis(1, at = seq(1, nrow(agg_Spain), 3), labels = agg_Spain$Group.1[seq(1, nrow(agg_Spain), 3)])
plot(agg_Belgium$x, xaxt = "n", main = "Belgium NRCA", xlab = "Time", ylab = "NRCA")
axis(1, at = seq(1, nrow(agg_Belgium), 3), labels = agg_Belgium$Group.1[seq(1, nrow(agg_Belgium), 3)])
View(agg_Belgium)
