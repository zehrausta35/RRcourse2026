# Plot results
for (country in COUNTRIES) {
df <- results[[country]]
plot(df$x, main = paste(country, "NRCA"),
xaxt = "n", type = "l")
axis(1,
at = seq(1, nrow(df), 3),
labels = df$Group.1[seq(1, nrow(df), 3)])
}
